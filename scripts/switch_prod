#!/usr/bin/env bash
# switch_prod — kill dev/preview processes and restart the installed production agent
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
LABEL="$(sed -n 's/^LABEL="\([^"]*\)".*/\1/p' "${ROOT}/install.sh")"
APP="$(python3 -c "import json; print(json.load(open('${ROOT}/src-tauri/tauri.conf.json'))['productName'])")"
APP_LOWER="$(echo "${APP}" | tr '[:upper:]' '[:lower:]')"
PLIST="${HOME}/Library/LaunchAgents/${LABEL}.plist"

if [[ ! -f "${PLIST}" ]]; then
    echo "No plist at ${PLIST} — run install.sh first."
    exit 1
fi

echo "Killing all instances..."
pkill -x "${APP}" 2>/dev/null || true
pkill -x "${APP_LOWER}" 2>/dev/null || true
pkill -f "Contents/MacOS/${APP}" 2>/dev/null || true
pkill -f "target/debug/${APP_LOWER}" 2>/dev/null || true
pkill -f "target/release/bundle/macos/${APP}" 2>/dev/null || true
pkill -f "cargo tauri dev" 2>/dev/null || true
pkill -f "vite" 2>/dev/null || true

if lsof -ti:1420 &>/dev/null 2>&1; then
    kill "$(lsof -ti:1420)" 2>/dev/null || true
fi

sleep 1

echo "Starting production agent (${LABEL})..."
launchctl bootstrap "gui/$(id -u)" "${PLIST}"
echo "Done."
