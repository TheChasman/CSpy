{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CSpy",
  "version": "0.1.1",
  "identifier": "com.nrtfm.cspy",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bash scripts/dev.sh",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "popover",
        "title": "CSpy",
        "width": 290,
        "height": 240,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "14.0",
      "exceptionDomain": ""
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/TheChasman/CSpy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCNDA0NzU1M0YwQjk3MEMKUldRTWx3cy9WVWRBdTRMdDhPcW9kaFUyZlIvY3FYeFJ6UDEyNXBxclpMdTlacWlFdzJEeEJ1ZlkK"
    }
  }
}
